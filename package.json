{
  "name": "@hanzo/theming",
  "version": "6.0.0",
  "description": "Theme engine, palette generation, and themed components for Hanzo-powered apps",
  "exports": {
    "./hanzogui-config": {
      "types": "./hanzogui/create-config.d.ts",
      "import": "./hanzogui/create-config.js"
    },
    "./themed-components": {
      "types": "./hanzogui/components/index.d.ts",
      "import": "./hanzogui/components/index.js"
    },
    "./hanzogui-config-defaults": {
      "types": "./hanzogui/defaults/index.d.ts",
      "import": "./hanzogui/defaults/index.js"
    },
    "./shadcn-semantic-tw-colors.css": "./hanzo-ui/shadcn-semantic-colors.css"
  },
  "bin": {
    "generate-palettes": "./hanzo-ui/generate-palettes.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "tc": "tsc --noEmit",
    "build": "rm -rf dist && tsc && tsup src/hanzo-ui/generate-palettes.ts --format cjs,esm --dts --outDir dist/hanzo-ui && cp src/hanzo-ui/shadcn-semantic-colors.css dist/hanzo-ui/ && node scripts/prepare-dist.mjs",
    "pub": "./scripts/publish.sh"
  },
  "peerDependencies": {
    "@hanzogui/animations-react-native": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/config-default": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/shorthands": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/theme-builder": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "@hanzogui/web": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "hanzogui": ">=2.0.0-rc.41-hanzoai.5 <2.0.0 || >=2.0.6 <3.0.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "author": "Hanzo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanzoai/theming"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  }
}
