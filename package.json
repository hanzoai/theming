{
  "name": "@hanzo/branding",
  "version": "4.1.3",
  "description": "Theme engine, palette generation, and themed components for Hanzo-powered apps",
  "exports": {
    "./tg-config": {
      "types": "./dist/tg/create-config.d.ts",
      "import": "./dist/tg/create-config.js"
    },
    "./tg-components": {
      "types": "./dist/tg/components/index.d.ts",
      "import": "./dist/tg/components/index.js"
    },
    "./tg-config-defaults": {
      "types": "./dist/tg/defaults/index.d.ts",
      "import": "./dist/tg/defaults/index.js"
    },
    "./shadcn-semantic-tw-colors.css": "./src/shadcn-tw/shadcn-semantic-colors.css"
  },
  "bin": {
    "generate-palettes": "./dist/generate-palettes.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "tc": "tsc --noEmit",
    "build": "rm -rf dist && tsc && tsup src/shadcn-tw/generate-palettes.ts --format cjs,esm --dts --outDir dist/shadcn-tw",
    "pub": "./scripts/publish.sh"
  },
  "dependencies": {
    "@hanzogui/config-default": "3.0.6",
    "@hanzogui/shorthands": "3.0.6",
    "@hanzogui/theme-builder": "3.0.6",
    "@hanzogui/web": "3.0.6"
  },
  "peerDependencies": {
    "@hanzo/gui": ">=4.3.2",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "author": "Hanzo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanzoai/branding"
  },
  "publishConfig": {
    "access": "public"
  }
}
